# Copy to .env for local secrets (never commit .env)
# NOAA_CDO_TOKEN= # NCEI Climate Data Online — https://www.ncdc.noaa.gov/cdo-web/token
#
# Surfrider BWTF (Tier 4): paste Cognito IdToken (JWT) after logging in at https://bwtf.surfrider.org/
# DevTools → Application → Local Storage → CognitoIdentityServiceProvider.*.idToken
# Tokens expire (~1h); refresh for long date-range pulls.
# BWTF_COGNITO_ID_TOKEN=
